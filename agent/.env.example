# Arc Agent — Environment Configuration
# Copy this to .env and fill in values
# NEVER commit .env to git

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...         # Your personal chat ID with the bot

# GitHub (personal access token, repo scope)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=tombrau/ai-coder-evolution

# Project paths on server
PROJECT_DIR=/opt/arc/project
SESSIONS_DIR=/opt/arc/project/sessions
PRIVATE_DIR=/opt/arc/private      # Separate from local .private/

# Model to use for Arc API calls
CLAUDE_MODEL=claude-sonnet-4-5-20251001

# Schedule (cron expressions)
WEEKLY_CHECK_CRON=0 9 * * 1       # Monday 9am
DAILY_HEARTBEAT=0 8 * * *          # 8am daily (optional, can disable)
